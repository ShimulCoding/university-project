# Backend environment variables
# Copy this file to .env before running the backend.

# Application mode
NODE_ENV=development

# Express server port
PORT=4000

# Frontend origin allowed by CORS
# Multiple origins can be separated with commas
FRONTEND_URL=http://localhost:3000

# PostgreSQL connection string for Prisma
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/mu_cse_transparency

# Use long random secrets in real environments
JWT_ACCESS_SECRET=replace-with-long-random-access-secret
JWT_REFRESH_SECRET=replace-with-long-random-refresh-secret

# Token lifetimes
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=7d

# Cookie names
ACCESS_TOKEN_COOKIE_NAME=mu_access_token
REFRESH_TOKEN_COOKIE_NAME=mu_refresh_token

# Password hashing cost
BCRYPT_SALT_ROUNDS=12

# Local upload directory for development
UPLOADS_ROOT=uploads
