{
    "name":  "university-project",
    "private":  true,
    "version":  "0.1.0",
    "workspaces":  [
                       "frontend",
                       "backend"
                   ],
    "scripts":  {
                    "dev:frontend":  "npm run dev --workspace frontend",
                    "dev:backend":  "npm run dev --workspace backend",
                    "build":  "npm run build --workspace frontend \u0026\u0026 npm run build --workspace backend",
                    "lint":  "npm run lint --workspace frontend",
                    "db:generate":  "npm run prisma:generate --workspace backend",
                    "db:migrate":  "npm run prisma:migrate:dev --workspace backend",
                    "dev":  "concurrently -k -n backend,frontend -c blue,magenta \"npm:dev:backend\" \"npm:dev:frontend\""
                },
    "devDependencies":  {
                            "concurrently":  "^9.2.1"
                        }
}
